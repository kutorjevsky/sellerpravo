# Токен Telegram-бота от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# ID Google-таблицы (из её URL: docs.google.com/spreadsheets/d/=>ЭТОТ_ID<=/edit)
SPREADSHEET_ID=

# Учётные данные сервисного аккаунта Google.
# Вариант А (для сервера/Railway): вставьте СОДЕРЖИМОЕ json-файла одной строкой:
GOOGLE_CREDENTIALS_JSON=

# Вариант Б (локально): путь к файлу ключа (если не используете переменную выше)
GOOGLE_CREDENTIALS_FILE=credentials.json
